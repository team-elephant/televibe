# ============================================================================
# Telegram Bot Configuration
# ============================================================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (numeric)
# To find your ID, message @userinfobot on Telegram
TELEGRAM_OWNER_ID=your_telegram_user_id_here

# ============================================================================
# Cursor CLI Configuration
# ============================================================================
# Get from Cursor settings > Account > API Key
CURSOR_API_KEY=your_cursor_api_key_here

# Path to the default project directory Cursor will operate in
# You can override this per-command or set it with /project command
# Example: /Users/admin/Projects/my-project
CURSOR_DEFAULT_PROJECT_DIR=/path/to/your/project

# Default mode for file modifications (true/false)
# When true, /prompt will also allow file writes
CURSOR_FORCE_MODE=false

# ============================================================================
# Claude (Anthropic) CLI Configuration
# ============================================================================
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Anthropic API endpoint (default: https://api.anthropic.com)
ANTHROPIC_ENDPOINT=https://api.anthropic.com

# ============================================================================
# Codex (OpenAI) CLI Configuration
# ============================================================================
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# OpenAI API endpoint (default: https://api.openai.com/v1)
OPENAI_ENDPOINT=https://api.openai.com/v1

# ============================================================================
# Grok (xAI) CLI Configuration
# ============================================================================
# Get your API key from https://console.x.ai/
GROK_API_KEY=your-grok-api-key-here

# xAI API endpoint (default: https://api.x.ai/v1)
GROK_ENDPOINT=https://api.x.ai/v1

# ============================================================================
# Legacy/Custom LLM Configuration (for advanced users)
# ============================================================================
# Add custom LLM API keys and endpoints using the format:
# <NAME>_API_KEY=your_api_key
# <NAME>_ENDPOINT=https://api.example.com/v1
#
# Examples:
#
# MiniMax (OpenAI-compatible):
# MINIMAX_API_KEY=your-minimax-key
# MINIMAX_ENDPOINT=https://api.minimax.chat/v1
#
# Any other OpenAI-compatible API:
# CUSTOM_API_KEY=your-api-key
# CUSTOM_ENDPOINT=https://your-api-endpoint.com/v1
#
# You can add multiple custom LLMs by using different prefixes.
# Then use the Telegram bot menu: Custom LLM Model → Add LLM
# ============================================================================
